moi-order-frontend/dist/
moi-order-frontend/web-build/
moi-order-frontend/*.ipa
moi-order-frontend/*.apk
moi-order-frontend/*.aab
moi-order-frontend/.env
moi-order-frontend/.env*.local

# ── Backend ───────────────────────────────────────────────────────────────────
moi-order-backend/vendor/
moi-order-backend/.env
moi-order-backend/storage/logs/
moi-order-backend/storage/app/
moi-order-backend/bootstrap/cache/

