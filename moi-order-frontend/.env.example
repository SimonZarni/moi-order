# Replace with your backend base URL for local or production use.
EXPO_PUBLIC_API_URL=https://your-api.example.com

# Public runtime config for the mobile app.
EXPO_PUBLIC_PUSHER_KEY=
EXPO_PUBLIC_PUSHER_CLUSTER=ap1
EXPO_PUBLIC_MAPBOX_TOKEN=
EXPO_PUBLIC_MAPBOX_STYLE=mapbox://styles/mapbox/streets-v12
EXPO_PUBLIC_LINE_CHANNEL_ID=2008805625

# Native build-time secret for the Mapbox SDK download step.
# Keep this out of git. Set it locally or in your CI/EAS environment.
RNMAPBOX_MAPS_DOWNLOAD_TOKEN=
