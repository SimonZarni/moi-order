# Merchant App — Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored. .env.example is committed (no secrets).
#
# EXPO_PUBLIC_* vars are bundled into JS and visible to the app.
# Change them → restart Metro (Ctrl+C then re-run start command).

# ── API ───────────────────────────────────────────────────────────────────────
EXPO_PUBLIC_API_URL=https://api.moiorder.com/api/merchant/v1

# ── WebSocket — pick ONE option and leave the other blank ─────────────────────

# Option A — Laravel Reverb (self-hosted, free, recommended)
# Run `php artisan reverb:install` on your backend to generate these values.
# They appear in your backend .env after installation.
EXPO_PUBLIC_REVERB_APP_KEY=
EXPO_PUBLIC_REVERB_HOST=api.moiorder.com
EXPO_PUBLIC_REVERB_PORT=8080
EXPO_PUBLIC_REVERB_SCHEME=https

# Option B — Pusher cloud (pusher.com → create a Channels app → Credentials tab)
EXPO_PUBLIC_PUSHER_APP_KEY=
EXPO_PUBLIC_PUSHER_APP_CLUSTER=ap1

# ── Social auth ───────────────────────────────────────────────────────────────
# Google — Google Cloud Console > APIs & Services > Credentials
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=

# LINE — LINE Developers Console > your Login channel > Channel ID
EXPO_PUBLIC_LINE_CHANNEL_ID=
EXPO_PUBLIC_LINE_WEB_REDIRECT_URI=https://merchant.moiorder.com/auth/line/callback

# Apple — Apple Developer Console > Services ID (web only; iOS uses native bundle ID)
EXPO_PUBLIC_APPLE_WEB_CLIENT_ID=com.moiorder.merchantweb
EXPO_PUBLIC_APPLE_WEB_REDIRECT_URI=https://merchant.moiorder.com/auth/apple/callback
