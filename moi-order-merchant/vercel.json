{
  "buildCommand": "npm run build:web",
  "outputDirectory": "dist",
  "build": {
    "env": {
      "EXPO_PUBLIC_API_URL": "https://api.moiorder.com/api/merchant/v1",

      "EXPO_PUBLIC_REVERB_APP_KEY":  "@reverb-app-key",
      "EXPO_PUBLIC_REVERB_HOST":     "api.moiorder.com",
      "EXPO_PUBLIC_REVERB_PORT":     "8080",
      "EXPO_PUBLIC_REVERB_SCHEME":   "https",

      "EXPO_PUBLIC_PUSHER_APP_KEY":     "@pusher-app-key",
      "EXPO_PUBLIC_PUSHER_APP_CLUSTER": "ap1"
    }
  },
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }]
}
